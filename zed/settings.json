// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "git_panel": {
    "dock": "left",
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "ui_font_weight": 400.0,
  "ui_font_family": "GeistMono Nerd Font",
  "auto_update_extensions": {
    "biome": false,
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "sticky_scroll": {
    "enabled": false,
  },
  "buffer_line_height": "comfortable",
  "inline_code_actions": true,
  "icon_theme": "Catppuccin Latte",
  "agent_buffer_font_size": 20.0,
  "agent_ui_font_size": 22.0,
  "agent": {
    "dock": "right",
    "default_profile": "write",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-opus-4-5-thinking",
    },
    "model_parameters": [],
    "button": false,
    "default_width": 720,
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "outline_panel": {
    "dock": "left",
    "button": false,
  },
  "debugger": {
    "save_breakpoints": true,
  },
  "use_smartcase_search": true,
  "buffer_font_family": "GeistMono Nerd Font",
  "terminal": {
    "font_family": "GeistMono Nerd Font",
    "button": false,
    "default_height": 800,
    "default_width": 1111,
    "dock": "bottom",
  },
  "search": {
    "button": false,
  },
  "gutter": {
    "runnables": false,
    "folds": false,
    "breakpoints": true,
    "line_numbers": false,
    "min_line_number_digits": 0,
  },
  "indent_guides": {
    "enabled": false,
  },
  "centered_layout": {
    "left_padding": 0.09,
    "right_padding": 0,
  },
  "current_line_highlight": "none",
  "hover_popover_enabled": false,
  "extend_comment_on_newline": false,
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "title_bar": {
    "show_project_items": false,
    "show_branch_name": false,
    "show_menus": false,
    "show_onboarding_banner": false,
    "show_user_menu": false,
  },
  "tab_bar": {
    "show_tab_bar_buttons": false,
  },
  "project_panel": {
    "hide_root": true,
    "auto_fold_dirs": false,
    "dock": "right",
    "default_width": 600,
  },
  "scrollbar": {
    "show": "never",
  },
  "vim_mode": true,
  "ui_font_size": 20.0,
  "buffer_font_size": 20.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Aura Dark (Soft Text)",
  },
  "theme_overrides": {
    "Aura Dark (Soft Text)": {
      "border.variant": "#15141C",
      "border": "#15141C",
      "title_bar.background": "#15141C",
      "panel.background": "#15141C",
      "panel.focused_border": "#4E466E",
      "players": [
        {
          "cursor": "#bd9dff",
        },
      ],
      "syntax": {
        "comment": {
          "font_style": "italic",
        },
        "comment.doc": {
          "font_style": "italic",
        },
      },
    },
  },
  "which_key": {
    "enabled": true,
  },
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "vim": {
    "use_smartcase_find": true,
  },
  "languages": {
    "SQL": {
      "show_edit_predictions": false,
    },
    "JavaScript": {
      "formatter": "none",
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "Vue.js": {
      "formatter": "none",
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TypeScript": {
      "formatter": "none",
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "Python": {
      "language_servers": ["pyrefly", "!pyright", "!pylsp"],
    },
  },
}
